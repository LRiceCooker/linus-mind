n\n.commit-body {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  font-size: 1.0625rem;\n  line-height: 1.9;\n  letter-spacing: 0.003em;\n  color: var(--text);\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-wrap: break-word;\n}\n\n@media (min-width: 640px) {\n  .commit-body {\n    font-size: 1.125rem;\n  }\n}\n\n.lead-in {\n  font-variant: small-caps;\n  font-weight: 600;\n  letter-spacing: 0.05em;\n}\n\n.commit-footer {\n  margin-top: auto;\n  padding-top: var(--space-10);\n}\n\n.commit-meta-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n}\n\n.commit-date {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.75rem;\n  line-height: 1;\n  letter-spacing: 0.01em;\n  color: var(--text-secondary);\n}\n\n@media (min-width: 640px) {\n  .commit-date {\n    font-size: 0.8125rem;\n  }\n}\n\n.commit-sha {\n  font-family: var(--font-mono);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.05em;\n  color: var(--text-tertiary);\n}\n\n@media (min-width: 640px) {\n  .commit-sha {\n    font-size: 0.6875rem;\n  }\n}\n\n.commit-counter {\n  text-align: center;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.04em;\n  color: var(--text-tertiary);\n  margin-top: var(--space-2);\n}\n\n@media (min-width: 640px) {\n  .commit-counter {\n    font-size: 0.6875rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Spinner — §6.7\n   ------------------------------------------------------------------- */\n.spinner-wrapper {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":195,"cache_read_input_tokens":82808,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":195},"output_tokens":73,"service_tier":"standard","inference_geo":"not_available"},"context_ma