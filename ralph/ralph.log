----------------------------------- */\n:root {\n  /* Colors — §3 Light mode */\n  --bg:             #f8f6f1;\n  --bg-elevated:    #f3f0ea;\n  --bg-hover:       #efece5;\n  --bg-active:      #e8e4dc;\n  --text:           #2c2c2c;\n  --text-secondary: #8a8580;\n  --text-tertiary:  #b5b0a8;\n  --accent:         #b8976a;\n  --divider:        #e4e0d8;\n  --selection:      rgba(184, 151, 106, 0.2);\n\n  /* Font stacks — §4 */\n  --font-serif: 'Source Serif 4', Georgia, 'Noto Serif', serif;\n  --font-sans:  'Inter', system-ui, -apple-system, sans-serif;\n  --font-mono:  'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;\n\n  /* Spacing tokens — §5 */\n  --space-1:  0.25rem;\n  --space-2:  0.5rem;\n  --space-3:  0.75rem;\n  --space-4:  1rem;\n  --space-5:  1.25rem;\n  --space-6:  1.5rem;\n  --space-8:  2rem;\n  --space-10: 2.5rem;\n  --space-12: 3rem;\n  --space-16: 4rem;\n  --space-20: 5rem;\n  --space-24: 6rem;\n\n  /* Page padding — §5 */\n  --pad: 24px;\n}\n\n@media (min-width: 640px) {\n  :root {\n    --pad: 40px;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Custom Properties — Dark mode\n   ------------------------------------------------------------------- */\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg:             #1a1916;\n    --bg-elevated:    #222019;\n    --bg-hover:       #2a2720;\n    --bg-active:      #333028;\n    --text:           #d9d4ca;\n    --text-secondary: #7d786f;\n    --text-tertiary:  #4a4740;\n    --accent:         #c9a96e;\n    --divider:        #2e2b25;\n    --selection:      rgba(201, 169, 110, 0.25);\n  }\n}\n\n/* -------------------------------------------------------------------\n   Base Reset\n   ------------------------------------------------------------------- */\n*,\n*::before,\n*::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* -------------------------------------------------------------------\n   Base Styles — html / body\n   ------------------------------------------------------------------- */\nhtml {\n  font-size: 16px;\n  -webkit-text-size-adjust: 100%;\n  text-size-adjust: 100%;\n}\n\nbody {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  color: var(--text);\n  background-color: var(--bg);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* -------------------------------------------------------------------\n   Text Selection — §3\n   ------------------------------------------------------------------- */\n::selection {\n  background: var(--selection);\n}\n\n/* -------------------------------------------------------------------\n   Screen Reader Only — §9\n   ------------------------------------------------------------------- */\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.sr-only-focusable:focus {\n  position: static;\n  width: auto;\n  height: auto;\n  padding: 0.5rem 1rem;\n  margin: 0;\n  overflow: visible;\n  clip: auto;\n  white-space: normal;\n}\n\n/* -------------------------------------------------------------------\n   Reduced Motion — §8\n   ------------------------------------------------------------------- */\n@media (prefers-reduced-motion: reduce) {\n  *,\n  *::before,\n  *::after {\n    animation-duration: 0.01ms !important;\n    transition-duration: 0.01ms !important;\n    scroll-behavior: auto !important;\n  }\n}\n","structuredPatch":[{"oldStart":130,"oldLines":6,"newStart":130,"newLines":200,"lines":[" }"," "," /* -------------------------------------------------------------------","+   Content Container","+   ------------------------------------------------------------------- */","+.repo-list {","+  max-width: 42rem;","+  margin: 0 auto;","+  padding: 0 var(--pad);","+}","+","+/* -------------------------------------------------------------------","+   Hero — §6.1","+   ------------------------------------------------------------------- */","+.hero {","+  display: flex;","+  flex-direction: column;","+  align-items: center;","+  justify-content: center;","+  text-align: center;","+  min-height: 15vh;","+  padding: var(--space-10) var(--pad) var(--space-8);","+}","+","+.hero-title {","+  font-family: var(--font-serif);","+  font-weight: 300;","+  font-size: 2.25rem;","+  line-height: 1.1;","+  letter-spacing: -0.04em;","+  color: var(--text);","+}","+","+.hero-tagline {","+  font-family: var(--font-sans);","+  font-weight: 400;","+  font-size: 0.8125rem;","+  line-height: 1.6;","+  letter-spacing: 0.02em;","+  color: var(--text-secondary);","+  margin-top: var(--space-3);","+  text-transform: lowercase;","+}","+","+.dinkus {","+  font-size: 0.75rem;","+  color: var(--text-tertiary);","+  margin-top: var(--space-6);","+  letter-spacing: 0.2em;","+}","+","+@media (min-width: 640px) {","+  .hero {","+    min-height: 25vh;","+    padding: var(--space-16) var(--pad) var(--space-12);","+  }","+","+  .hero-title {","+    font-size: 3rem;","+  }","+","+  .hero-tagline {","+    font-size: 0.875rem;","+  }","+}","+","+/* -------------------------------------------------------------------","+   Repo Cards — §6.2","+   ------------------------------------------------------------------- */","+.repo-list-items {","+  padding-top: var(--space-4);","+}","+","+.repo-card {","+  display: block;","+  padding: var(--space-6) 0;","+  border-bottom: 1px solid var(--divider);","+  text-decoration: none;","+  color: inherit;","+  transition: background 200ms ease;","+}","+","+.repo-card:first-child {","+  border-top: 1px solid var(--divider);","+}","+","+.repo-name {","+  display: block;","+  font-family: var(--font-serif);","+  font-weight: 600;","+  font-size: 1.1875rem;","+  line-height: 1.3;","+  letter-spacing: -0.01em;","+  color: var(--text);","+}","+","+.repo-description {","+  display: -webkit-box;","+  -webkit-line-clamp: 2;","+  -webkit-box-orient: vertical;","+  overflow: hidden;","+  font-family: var(--font-serif);","+  font-style: italic;","+  font-weight: 400;","+  font-size: 0.875rem;","+  line-height: 1.55;","+  color: var(--text-secondary);","+  margin-top: var(--space-1);","+}","+","+.repo-meta {","+  display: block;","+  font-family: var(--font-sans);","+  font-weight: 400;","+  font-size: 0.6875rem;","+  line-height: 1.4;","+  letter-spacing: 0.01em;","+  color: var(--text-tertiary);","+  margin-top: var(--space-2);","+}","+","+@media (min-width: 640px) {","+  .repo-name {","+    font-size: 1.375rem;","+  }","+","+  .repo-description {","+    font-size: 0.9375rem;","+  }","+","+  .repo-meta {","+    font-size: 0.75rem;","+  }","+}","+","+/* Hover — desktop only, full-bleed background */","+@media (hover: hover) {","+  .repo-card {","+    margin: 0 calc(var(--pad) * -1);","+    padding-left: var(--pad);","+    padding-right: var(--pad);","+  }","+","+  .repo-card:hover {","+    background: var(--bg-hover);","+  }","+","+  .repo-card:active {","+    background: var(--bg-active);","+    transition-duration: 80ms;","+  }","+}","+","+/* Focus-visible */","+.repo-card:focus-visible {","+  outline: 2px solid var(--accent);","+  outline-offset: 4px;","+  border-radius: 2px;","+}","+","+/* -------------------------------------------------------------------","+   Spinner — §6.7","+   ------------------------------------------------------------------- */","+.spinner-wrapper {","+  display: flex;","+  justify-content: center;","+  padding: var(--space-12) 0;","+}","+","+.spinner {","+  width: 20px;","+  height: 20px;","+  border: 1.5px solid var(--divider);","+  border-top-color: var(--accent);","+  border-radius: 50%;","+  animation: spin 0.8s linear infinite;","+}","+","+@keyframes spin {","+  to { transform: rotate(360deg); }","+}","+","+/* -------------------------------------------------------------------","+   Error / Empty States — §6.8","+   ------------------------------------------------------------------- */","+.error-message {","+  text-align: center;","+  font-family: var(--font-sans);","+  font-weight: 400;","+  font-size: 0.9rem;","+  line-height: 1.6;","+  color: var(--text-secondary);","+  max-width: 28rem;","+  margin: var(--space-12) auto 0;","+}","+","+/* -------------------------------------------------------------------","    Reduced Motion — §8","    ------------------------------------------------------------------- */"," @media (prefers-reduced-motion: reduce) {"]}],"userModified":false,"replaceAll":false}}
