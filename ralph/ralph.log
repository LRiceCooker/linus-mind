n  }\n}\n\n/* -------------------------------------------------------------------\n   Custom Properties — Dark mode\n   ------------------------------------------------------------------- */\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg:             #1a1916;\n    --bg-elevated:    #222019;\n    --bg-hover:       #2a2720;\n    --bg-active:      #333028;\n    --text:           #d9d4ca;\n    --text-secondary: #7d786f;\n    --text-tertiary:  #4a4740;\n    --accent:         #c9a96e;\n    --divider:        #2e2b25;\n    --selection:      rgba(201, 169, 110, 0.25);\n  }\n}\n\n/* -------------------------------------------------------------------\n   Base Reset\n   ------------------------------------------------------------------- */\n*,\n*::before,\n*::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* -------------------------------------------------------------------\n   Base Styles — html / body\n   ------------------------------------------------------------------- */\nhtml {\n  font-size: 16px;\n  -webkit-text-size-adjust: 100%;\n  text-size-adjust: 100%;\n}\n\nbody {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  color: var(--text);\n  background-color: var(--bg);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* -------------------------------------------------------------------\n   Text Selection — §3\n   ------------------------------------------------------------------- */\n::selection {\n  background: var(--selection);\n}\n\n/* -------------------------------------------------------------------\n   Screen Reader Only — §9\n   ------------------------------------------------------------------- */\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.sr-only-focusable:focus {\n  position: static;\n  width: auto;\n  height: auto;\n  padding: 0.5rem 1rem;\n  margin: 0;\n  overflow: visible;\n  clip: auto;\n  white-space: normal;\n}\n\n/* -------------------------------------------------------------------\n   Reduced Motion — §8\n   ------------------------------------------------------------------- */\n@media (prefers-reduced-motion: reduce) {\n  *,\n  *::before,\n  *::after {\n    animation-duration: 0.01ms !important;\n    transition-duration: 0.01ms !important;\n    scroll-behavior: auto !important;\n  }\n}\n","structuredPatch":[],"originalFile":null}}
