{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015mbmBwgkj8CrVAhDqCGbNV","type":"tool_result","content":"1\t/* ===================================================================\n2\t   linus-mind — Design System\n3\t   A literary web reader. Typography-driven, zero chrome, warm tones.\n4\t   =================================================================== */\n5\t\n6\t/* -------------------------------------------------------------------\n7\t   Custom Properties — Light mode (default)\n8\t   ------------------------------------------------------------------- */\n9\t:root {\n10\t  /* Colors — §3 Light mode */\n11\t  --bg:             #f8f6f1;\n12\t  --bg-elevated:    #f3f0ea;\n13\t  --bg-hover:       #efece5;\n14\t  --bg-active:      #e8e4dc;\n15\t  --text:           #2c2c2c;\n16\t  --text-secondary: #8a8580;\n17\t  --text-tertiary:  #b5b0a8;\n18\t  --accent:         #b8976a;\n19\t  --divider:        #e4e0d8;\n20\t  --selection:      rgba(184, 151, 106, 0.2);\n21\t\n22\t  /* Font stacks — §4 */\n23\t  --font-serif: 'Source Serif 4', Georgia, 'Noto Serif', serif;\n24\t  --font-sans:  'Inter', system-ui, -apple-system, sans-serif;\n25\t  --font-mono:  'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;\n26\t\n27\t  /* Spacing tokens — §5 */\n28\t  --space-1:  0.25rem;\n29\t  --space-2:  0.5rem;\n30\t  --space-3:  0.75rem;\n31\t  --space-4:  1rem;\n32\t  --space-5:  1.25rem;\n33\t  --space-6:  1.5rem;\n34\t  --space-8:  2rem;\n35\t  --space-10: 2.5rem;\n36\t  --space-12: 3rem;\n37\t  --space-16: 4rem;\n38\t  --space-20: 5rem;\n39\t  --space-24: 6rem;\n40\t\n41\t  /* Page padding — §5 */\n42\t  --pad: 24px;\n43\t}\n44\t\n45\t@media (min-width: 640px) {\n46\t  :root {\n47\t    --pad: 40px;\n48\t  }\n49\t}\n50\t\n51\t/* -------------------------------------------------------------------\n52\t   Custom Properties — Dark mode\n53\t   ------------------------------------------------------------------- */\n54\t@media (prefers-color-scheme: dark) {\n55\t  :root {\n56\t    --bg:             #1a1916;\n57\t    --bg-elevated:    #222019;\n58\t    --bg-hover:       #2a2720;\n59\t    --bg-active:      #333028;\n60\t    --text:           #d9d4ca;\n61\t    --text-secondary: #7d786f;\n62\t    --text-tertiary:  #4a4740;\n63\t    --accent:         #c9a96e;\n64\t    --divider:        #2e2b25;\n65\t    --selection:      rgba(201, 169, 110, 0.25);\n66\t  }\n67\t}\n68\t\n69\t/* -------------------------------------------------------------------\n70\t   Base Reset\n71\t   ------------------------------------------------------------------- */\n72\t*,\n73\t*::before,\n74\t*::after {\n75\t  margin: 0;\n76\t  padding: 0;\n77\t  box-sizing: border-box;\n78\t}\n79\t\n80\t/* -------------------------------------------------------------------\n81\t   Base Styles — html / body\n82\t   ------------------------------------------------------------------- */\n83\thtml {\n84\t  font-size: 16px;\n85\t  -webkit-text-size-adjust: 100%;\n86\t  text-size-adjust: 100%;\n87\t}\n88\t\n89\tbody {\n90\t  font-family: var(--font-serif);\n91\t  font-weight: 400;\n92\t  color: var(--text);\n93\t  background-color: var(--bg);\n94\t  line-height: 1.6;\n95\t  -webkit-font-smoothing: antialiased;\n96\t  -moz-osx-font-smoothing: grayscale;\n97\t}\n98\t\n99\t/* -------------------------------------------------------------------\n100\t   Text Selection — §3\n101\t   ------------------------------------------------------------------- */\n102\t::selection {\n103\t  background: var(--selection);\n104\t}\n105\t\n106\t/* -------------------------------------------------------------------\n107\t   Screen Reader Only — §9\n108\t   ------------------------------------------------------------------- */\n109\t.sr-only {\n110\t  position: absolute;\n111\t  width: 1px;\n112\t  height: 1px;\n113\t  padding: 0;\n114\t  margin: -1px;\n115\t  overflow: hidden;\n116\t  clip: rect(0, 0, 0, 0);\n117\t  white-space: nowrap;\n118\t  border: 0;\n119\t}\n120\t\n121\t.sr-only-focusable:focus {\n122\t  position: static;\n123\t  width: auto;\n124\t  height: auto;\n125\t  padding: 0.5rem 1rem;\n126\t  margin: 0;\n127\t  overflow: visible;\n128\t  clip: auto;\n129\t  white-space: normal;\n130\t}\n131\t\n132\t/* -------------------------------------------------------------------\n133\t   View Transitions — §8\n134\t   ------------------------------------------------------------------- */\n135\t.view {\n136\t  opacity: 0;\n137\t  transition: opacity 250ms ease;\n138\t}\n139\t\n140\t.view.view-visible {\n141\t  opacity: 1;\n142\t}\n143\t\n144\t.view.view-hidden {\n145\t  opacity: 0;\n146\t}\n147\t\n148\t/* -------------------------------------------------------------------\n149\t   Content Container\n150\t   ------------------------------------------------------------------- */\n151\t.repo-list {\n152\t  max-width: 42rem;\n153\t  margin: 0 auto;\n154\t  padding: 0 var(--pad);\n155\t}\n156\t\n157\t/* -------------------------------------------------------------------\n158\t   Hero — §6.1\n159\t   ------------------------------------------------------------------- */\n160\t.hero {\n161\t  display: flex;\n162\t  flex-direction: column;\n163\t  align-items: center;\n164\t  justify-content: center;\n165\t  text-align: center;\n166\t  min-height: 15vh;\n167\t  padding: var(--space-10) var(--pad) var(--space-8);\n168\t}\n169\t\n170\t.hero-title {\n171\t  font-family: var(--font-serif);\n172\t  font-weight: 300;\n173\t  font-size: 2.25rem;\n174\t  line-height: 1.1;\n175\t  letter-spacing: -0.04em;\n176\t  color: var(--text);\n177\t}\n178\t\n179\t.hero-tagline {\n180\t  font-family: var(--font-sans);\n181\t  font-weight: 400;\n182\t  font-size: 0.8125rem;\n183\t  line-height: 1.6;\n184\t  letter-spacing: 0.02em;\n185\t  color: var(--text-secondary);\n186\t  margin-top: var(--space-3);\n187\t  text-transform: lowercase;\n188\t}\n189\t\n190\t.dinkus {\n191\t  font-size: 0.75rem;\n192\t  color: var(--text-tertiary);\n193\t  margin-top: var(--space-6);\n194\t  letter-spacing: 0.2em;\n195\t}\n196\t\n197\t@media (min-width: 640px) {\n198\t  .hero {\n199\t    min-height: 25vh;\n200\t    padding: var(--space-16) var(--pad) var(--space-12);\n201\t  }\n202\t\n203\t  .hero-title {\n204\t    font-size: 3rem;\n205\t  }\n206\t\n207\t  .hero-tagline {\n208\t    font-size: 0.875rem;\n209\t  }\n210\t}\n211\t\n212\t/* -------------------------------------------------------------------\n213\t   Repo Cards — §6.2\n214\t   ------------------------------------------------------------------- */\n215\t.repo-list-items {\n216\t  padding-top: var(--space-4);\n217\t}\n218\t\n219\t.repo-card {\n220\t  display: block;\n221\t  padding: var(--space-6) 0;\n222\t  border-bottom: 1px solid var(--divider);\n223\t  text-decoration: none;\n224\t  color: inherit;\n225\t  transition: background 200ms ease;\n226\t}\n227\t\n228\t.repo-card:first-child {\n229\t  border-top: 1px solid var(--divider);\n230\t}\n231\t\n232\t.repo-name {\n233\t  display: block;\n234\t  font-family: var(--font-serif);\n235\t  font-weight: 600;\n236\t  font-size: 1.1875rem;\n237\t  line-height: 1.3;\n238\t  letter-spacing: -0.01em;\n239\t  color: var(--text);\n240\t}\n241\t\n242\t.repo-description {\n243\t  display: -webkit-box;\n244\t  -webkit-line-clamp: 2;\n245\t  -webkit-box-orient: vertical;\n246\t  overflow: hidden;\n247\t  font-family: var(--font-serif);\n248\t  font-style: italic;\n249\t  font-weight: 400;\n250\t  font-size: 0.875rem;\n251\t  line-height: 1.55;\n252\t  color: var(--text-secondary);\n253\t  margin-top: var(--space-1);\n254\t}\n255\t\n256\t.repo-meta {\n257\t  display: block;\n258\t  font-family: var(--font-sans);\n259\t  font-weight: 400;\n260\t  font-size: 0.6875rem;\n261\t  line-height: 1.4;\n262\t  letter-spacing: 0.01em;\n263\t  color: var(--text-tertiary);\n264\t  margin-top: var(--space-2);\n265\t}\n266\t\n267\t@media (min-width: 640px) {\n268\t  .repo-name {\n269\t    font-size: 1.375rem;\n270\t  }\n271\t\n272\t  .repo-description {\n273\t    font-size: 0.9375rem;\n274\t  }\n275\t\n276\t  .repo-meta {\n277\t    font-size: 0.75rem;\n278\t  }\n279\t}\n280\t\n281\t/* Hover — desktop only, full-bleed background */\n282\t@media (hover: hover) {\n283\t  .repo-card {\n284\t    margin: 0 calc(var(--pad) * -1);\n285\t    padding-left: var(--pad);\n286\t    padding-right: var(--pad);\n287\t  }\n288\t\n289\t  .repo-card:hover {\n290\t    background: var(--bg-hover);\n291\t  }\n292\t\n293\t  .repo-card:active {\n294\t    background: var(--bg-active);\n295\t    transition-duration: 80ms;\n296\t  }\n297\t}\n298\t\n299\t/* Focus-visible */\n300\t.repo-card:focus-visible {\n301\t  outline: 2px solid var(--accent);\n302\t  outline-offset: 4px;\n303\t  border-radius: 2px;\n304\t}\n305\t\n306\t/* -------------------------------------------------------------------\n307\t   Chapter Title Page — §6.3\n308\t   ------------------------------------------------------------------- */\n309\t.chapter-title {\n310\t  display: flex;\n311\t  flex-direction: column;\n312\t  align-items: center;\n313\t  justify-content: center;\n314\t  min-height: 100dvh;\n315\t  text-align: center;\n316\t  padding: var(--pad);\n317\t  scroll-snap-align: start;\n318\t}\n319\t\n320\t.chapter-title-content {\n321\t  flex: 1;\n322\t  display: flex;\n323\t  flex-direction: column;\n324\t  align-items: center;\n325\t  justify-content: center;\n326\t}\n327\t\n328\t.chapter-name {\n329\t  font-family: var(--font-serif);\n330\t  font-weight: 300;\n331\t  font-size: 1.875rem;\n332\t  line-height: 1.15;\n333\t  letter-spacing: -0.03em;\n334\t  color: var(--text);\n335\t}\n336\t\n337\t.chapter-description {\n338\t  font-family: var(--font-serif);\n339\t  font-style: italic;\n340\t  font-weight: 400;\n341\t  font-size: 0.9375rem;\n342\t  line-height: 1.6;\n343\t  color: var(--text-secondary);\n344\t  margin-top: var(--space-3);\n345\t  max-width: 28rem;\n346\t}\n347\t\n348\t.chapter-title .dinkus {\n349\t  margin-top: var(--space-8);\n350\t}\n351\t\n352\t@media (min-width: 640px) {\n353\t  .chapter-name {\n354\t    font-size: 2.5rem;\n355\t  }\n356\t\n357\t  .chapter-description {\n358\t    font-size: 1rem;\n359\t  }\n360\t}\n361\t\n362\t/* Scroll prompt — fades after 4s */\n363\t.scroll-prompt {\n364\t  display: flex;\n365\t  flex-direction: column;\n366\t  align-items: center;\n367\t  gap: var(--space-2);\n368\t  padding-bottom: var(--space-10);\n369\t  animation: promptFade 1200ms ease-out 4s forwards;\n370\t}\n371\t\n372\t.scroll-prompt-text {\n373\t  font-family: var(--font-sans);\n374\t  font-weight: 400;\n375\t  font-size: 0.6875rem;\n376\t  line-height: 1;\n377\t  letter-spacing: 0.08em;\n378\t  color: var(--text-tertiary);\n379\t  text-transform: uppercase;\n380\t}\n381\t\n382\t.scroll-prompt-arrow {\n383\t  font-size: 1rem;\n384\t  color: var(--text-tertiary);\n385\t  animation: bounce 1.8s ease-in-out infinite;\n386\t}\n387\t\n388\t@keyframes promptFade {\n389\t  to { opacity: 0; visibility: hidden; }\n390\t}\n391\t\n392\t@keyframes bounce {\n393\t  0%, 100% { transform: translateY(0); }\n394\t  50% { transform: translateY(6px); }\n395\t}\n396\t\n397\t@media (min-width: 640px) {\n398\t  .scroll-prompt-text {\n399\t    font-size: 0.75rem;\n400\t  }\n401\t}\n402\t\n403\t/* -------------------------------------------------------------------\n404\t   Scroll Container — §6.3\n405\t   ------------------------------------------------------------------- */\n406\t.scroll-container {\n407\t  height: 100dvh;\n408\t  overflow-y: auto;\n409\t  scroll-snap-type: y mandatory;\n410\t  -webkit-overflow-scrolling: touch;\n411\t  overscroll-behavior-y: contain;\n412\t}\n413\t\n414\t/* -------------------------------------------------------------------\n415\t   Commit Page — §6.4\n416\t   ------------------------------------------------------------------- */\n417\t.commit-page {\n418\t  display: flex;\n419\t  flex-direction: column;\n420\t  min-height: 100dvh;\n421\t  scroll-snap-align: start;\n422\t  opacity: 0;\n423\t  transform: translateY(12px);\n424\t  transition: opacity 400ms ease-out, transform 400ms ease-out;\n425\t}\n426\t\n427\t.commit-page.visible {\n428\t  opacity: 1;\n429\t  transform: translateY(0);\n430\t}\n431\t\n432\t.reading-column {\n433\t  flex: 1;\n434\t  display: flex;\n435\t  flex-direction: column;\n436\t  max-width: 38rem;\n437\t  width: 100%;\n438\t  margin: 0 auto;\n439\t  padding: 64px var(--pad) 32px;\n440\t}\n441\t\n442\t@media (min-width: 640px) {\n443\t  .reading-column {\n444\t    padding-top: 80px;\n445\t    padding-bottom: 48px;\n446\t  }\n447\t}\n448\t\n449\t.commit-title {\n450\t  font-family: var(--font-serif);\n451\t  font-weight: 700;\n452\t  font-size: 1.3125rem;\n453\t  line-height: 1.35;\n454\t  letter-spacing: -0.015em;\n455\t  color: var(--text);\n456\t}\n457\t\n458\t@media (min-width: 640px) {\n459\t  .commit-title {\n460\t    font-size: 1.625rem;\n461\t  }\n462\t}\n463\t\n464\t.decorative-rule {\n465\t  width: 3rem;\n466\t  height: 1px;\n467\t  background: var(--divider);\n468\t  margin: var(--space-6) auto;\n469\t}\n470\t\n471\t.commit-body {\n472\t  font-family: var(--font-serif);\n473\t  font-weight: 400;\n474\t  font-size: 1.0625rem;\n475\t  line-height: 1.9;\n476\t  letter-spacing: 0.003em;\n477\t  color: var(--text);\n478\t  white-space: pre-wrap;\n479\t  word-break: break-word;\n480\t  overflow-wrap: break-word;\n481\t}\n482\t\n483\t@media (min-width: 640px) {\n484\t  .commit-body {\n485\t    font-size: 1.125rem;\n486\t  }\n487\t}\n488\t\n489\t.lead-in {\n490\t  font-variant: small-caps;\n491\t  font-weight: 600;\n492\t  letter-spacing: 0.05em;\n493\t}\n494\t\n495\t.commit-footer {\n496\t  margin-top: auto;\n497\t  padding-top: var(--space-10);\n498\t}\n499\t\n500\t.commit-meta-row {\n501\t  display: flex;\n502\t  justify-content: space-between;\n503\t  align-items: baseline;\n504\t}\n505\t\n506\t.commit-date {\n507\t  font-family: var(--font-sans);\n508\t  font-weight: 400;\n509\t  font-size: 0.75rem;\n510\t  line-height: 1;\n511\t  letter-spacing: 0.01em;\n512\t  color: var(--text-secondary);\n513\t}\n514\t\n515\t@media (min-width: 640px) {\n516\t  .commit-date {\n517\t    font-size: 0.8125rem;\n518\t  }\n519\t}\n520\t\n521\t.commit-sha {\n522\t  font-family: var(--font-mono);\n523\t  font-weight: 400;\n524\t  font-size: 0.625rem;\n525\t  line-height: 1;\n526\t  letter-spacing: 0.05em;\n527\t  color: var(--text-tertiary);\n528\t}\n529\t\n530\t@media (min-width: 640px) {\n531\t  .commit-sha {\n532\t    font-size: 0.6875rem;\n533\t  }\n534\t}\n535\t\n536\t.commit-counter {\n537\t  text-align: center;\n538\t  font-family: var(--font-sans);\n539\t  font-weight: 400;\n540\t  font-size: 0.625rem;\n541\t  line-height: 1;\n542\t  letter-spacing: 0.04em;\n543\t  color: var(--text-tertiary);\n544\t  margin-top: var(--space-2);\n545\t}\n546\t\n547\t@media (min-width: 640px) {\n548\t  .commit-counter {\n549\t    font-size: 0.6875rem;\n550\t  }\n551\t}\n552\t\n553\t/* -------------------------------------------------------------------\n554\t   Top Bar — §6.5\n555\t   ------------------------------------------------------------------- */\n556\t.top-bar {\n557\t  position: fixed;\n558\t  top: 0;\n559\t  left: 0;\n560\t  right: 0;\n561\t  z-index: 100;\n562\t  height: 48px;\n563\t  padding: 0 var(--pad);\n564\t  padding-top: env(safe-area-inset-top, 0);\n565\t  display: flex;\n566\t  align-items: center;\n567\t  gap: var(--space-3);\n568\t  background: var(--bg-elevated);\n569\t  backdrop-filter: blur(16px);\n570\t  -webkit-backdrop-filter: blur(16px);\n571\t  border-bottom: 1px solid var(--divider);\n572\t  opacity: 1;\n573\t  transform: translateY(0);\n574\t  transition: opacity 300ms ease, transform 300ms ease;\n575\t}\n576\t\n577\t.top-bar.hidden {\n578\t  opacity: 0;\n579\t  transform: translateY(-100%);\n580\t  pointer-events: none;\n581\t}\n582\t\n583\t.back-button {\n584\t  display: flex;\n585\t  align-items: center;\n586\t  justify-content: center;\n587\t  width: 44px;\n588\t  height: 44px;\n589\t  padding: 0;\n590\t  background: transparent;\n591\t  border: none;\n592\t  border-radius: 6px;\n593\t  cursor: pointer;\n594\t  font-family: var(--font-serif);\n595\t  font-size: 1.25rem;\n596\t  color: var(--text);\n597\t  transition: background 150ms ease;\n598\t}\n599\t\n600\t.back-button:hover {\n601\t  background: var(--bg-hover);\n602\t}\n603\t\n604\t.back-button:active {\n605\t  background: var(--bg-active);\n606\t}\n607\t\n608\t.back-button:focus-visible {\n609\t  outline: 2px solid var(--accent);\n610\t  outline-offset: 2px;\n611\t}\n612\t\n613\t.top-bar-title {\n614\t  font-family: var(--font-sans);\n615\t  font-weight: 500;\n616\t  font-size: 0.75rem;\n617\t  line-height: 1;\n618\t  color: var(--text-secondary);\n619\t  overflow: hidden;\n620\t  text-overflow: ellipsis;\n621\t  white-space: nowrap;\n622\t}\n623\t\n624\t@media (min-width: 640px) {\n625\t  .top-bar-title {\n626\t    font-size: 0.8125rem;\n627\t  }\n628\t}\n629\t\n630\t/* -------------------------------------------------------------------\n631\t   Reading Progress Bar — §6.6\n632\t   ------------------------------------------------------------------- */\n633\t.progress-bar {\n634\t  position: fixed;\n635\t  top: 0;\n636\t  left: 0;\n637\t  height: 2px;\n638\t  z-index: 200;\n639\t  background: var(--accent);\n640\t  opacity: 0.5;\n641\t  width: 0%;\n642\t  transition: width 300ms ease-out;\n643\t}\n644\t\n645\t/* -------------------------------------------------------------------\n646\t   Spinner — §6.7\n647\t   ------------------------------------------------------------------- */\n648\t.spinner-wrapper {\n649\t  display: flex;\n650\t  justify-content: center;\n651\t  padding: var(--space-12) 0;\n652\t}\n653\t\n654\t.spinner {\n655\t  width: 20px;\n656\t  height: 20px;\n657\t  border: 1.5px solid var(--divider);\n658\t  border-top-color: var(--accent);\n659\t  border-radius: 50%;\n660\t  animation: spin 0.8s linear infinite;\n661\t}\n662\t\n663\t@keyframes spin {\n664\t  to { transform: rotate(360deg); }\n665\t}\n666\t\n667\t/* -------------------------------------------------------------------\n668\t   Error / Empty States — §6.8\n669\t   ------------------------------------------------------------------- */\n670\t.error-message {\n671\t  text-align: center;\n672\t  font-family: var(--font-sans);\n673\t  font-weight: 400;\n674\t  font-size: 0.9rem;\n675\t  line-height: 1.6;\n676\t  color: var(--text-secondary);\n677\t  max-width: 28rem;\n678\t  margin: var(--space-12) auto 0;\n679\t}\n680\t\n681\t/* -------------------------------------------------------------------\n682\t   Reduced Motion — §8\n683\t   ------------------------------------------------------------------- */\n684\t@media (prefers-reduced-motion: reduce) {\n685\t  *,\n686\t  *::before,\n687\t  *::after {\n688\t    animation-duration: 0.01ms !important;\n689\t    transition-duration: 0.01ms !important;\n690\t    scroll-behavior: auto !important;\n691\t  }\n692\t}\n693\t"}]},"parent_tool_use_id":null,"session_id":"27f9d074-e552-4076-906c-5830713f721a","uuid":"f925567a-537c-4b08-bc1c-654b6fdbc62c","timestamp":"2026-04-26T15:41:05.607Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ricecooker/Sandbox/linus-mind/css/style.css","content":"/* ===================================================================\n   linus-mind — Design System\n   A literary web reader. Typography-driven, zero chrome, warm tones.\n   =================================================================== */\n\n/* -------------------------------------------------------------------\n   Custom Properties — Light mode (default)\n   ------------------------------------------------------------------- */\n:root {\n  /* Colors — §3 Light mode */\n  --bg:             #f8f6f1;\n  --bg-elevated:    #f3f0ea;\n  --bg-hover:       #efece5;\n  --bg-active:      #e8e4dc;\n  --text:           #2c2c2c;\n  --text-secondary: #8a8580;\n  --text-tertiary:  #b5b0a8;\n  --accent:         #b8976a;\n  --divider:        #e4e0d8;\n  --selection:      rgba(184, 151, 106, 0.2);\n\n  /* Font stacks — §4 */\n  --font-serif: 'Source Serif 4', Georgia, 'Noto Serif', serif;\n  --font-sans:  'Inter', system-ui, -apple-system, sans-serif;\n  --font-mono:  'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;\n\n  /* Spacing tokens — §5 */\n  --space-1:  0.25rem;\n  --space-2:  0.5rem;\n  --space-3:  0.75rem;\n  --space-4:  1rem;\n  --space-5:  1.25rem;\n  --space-6:  1.5rem;\n  --space-8:  2rem;\n  --space-10: 2.5rem;\n  --space-12: 3rem;\n  --space-16: 4rem;\n  --space-20: 5rem;\n  --space-24: 6rem;\n\n  /* Page padding — §5 */\n  --pad: 24px;\n}\n\n@media (min-width: 640px) {\n  :root {\n    --pad: 40px;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Custom Properties — Dark mode\n   ------------------------------------------------------------------- */\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg:             #1a1916;\n    --bg-elevated:    #222019;\n    --bg-hover:       #2a2720;\n    --bg-active:      #333028;\n    --text:           #d9d4ca;\n    --text-secondary: #7d786f;\n    --text-tertiary:  #4a4740;\n    --accent:         #c9a96e;\n    --divider:        #2e2b25;\n    --selection:      rgba(201, 169, 110, 0.25);\n  }\n}\n\n/* -------------------------------------------------------------------\n   Base Reset\n   ------------------------------------------------------------------- */\n*,\n*::before,\n*::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* -------------------------------------------------------------------\n   Base Styles — html / body\n   ------------------------------------------------------------------- */\nhtml {\n  font-size: 16px;\n  -webkit-text-size-adjust: 100%;\n  text-size-adjust: 100%;\n}\n\nbody {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  color: var(--text);\n  background-color: var(--bg);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* -------------------------------------------------------------------\n   Text Selection — §3\n   ------------------------------------------------------------------- */\n::selection {\n  background: var(--selection);\n}\n\n/* -------------------------------------------------------------------\n   Screen Reader Only — §9\n   ------------------------------------------------------------------- */\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.sr-only-focusable:focus {\n  position: static;\n  width: auto;\n  height: auto;\n  padding: 0.5rem 1rem;\n  margin: 0;\n  overflow: visible;\n  clip: auto;\n  white-space: normal;\n}\n\n/* -------------------------------------------------------------------\n   View Transitions — §8\n   ------------------------------------------------------------------- */\n.view {\n  opacity: 0;\n  transition: opacity 250ms ease;\n}\n\n.view.view-visible {\n  opacity: 1;\n}\n\n.view.view-hidden {\n  opacity: 0;\n}\n\n/* -------------------------------------------------------------------\n   Content Container\n   ------------------------------------------------------------------- */\n.repo-list {\n  max-width: 42rem;\n  margin: 0 auto;\n  padding: 0 var(--pad);\n}\n\n/* -------------------------------------------------------------------\n   Hero — §6.1\n   ------------------------------------------------------------------- */\n.hero {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  min-height: 15vh;\n  padding: var(--space-10) var(--pad) var(--space-8);\n}\n\n.hero-title {\n  font-family: var(--font-serif);\n  font-weight: 300;\n  font-size: 2.25rem;\n  line-height: 1.1;\n  letter-spacing: -0.04em;\n  color: var(--text);\n}\n\n.hero-tagline {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.8125rem;\n  line-height: 1.6;\n  letter-spacing: 0.02em;\n  color: var(--text-secondary);\n  margin-top: var(--space-3);\n  text-transform: lowercase;\n}\n\n.dinkus {\n  font-size: 0.75rem;\n  color: var(--text-tertiary);\n  margin-top: var(--space-6);\n  letter-spacing: 0.2em;\n}\n\n@media (min-width: 640px) {\n  .hero {\n    min-height: 25vh;\n    padding: var(--space-16) var(--pad) var(--space-12);\n  }\n\n  .hero-title {\n    font-size: 3rem;\n  }\n\n  .hero-tagline {\n    font-size: 0.875rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Repo Cards — §6.2\n   ------------------------------------------------------------------- */\n.repo-list-items {\n  padding-top: var(--space-4);\n}\n\n.repo-card {\n  display: block;\n  padding: var(--space-6) 0;\n  border-bottom: 1px solid var(--divider);\n  text-decoration: none;\n  color: inherit;\n  transition: background 200ms ease;\n}\n\n.repo-card:first-child {\n  border-top: 1px solid var(--divider);\n}\n\n.repo-name {\n  display: block;\n  font-family: var(--font-serif);\n  font-weight: 600;\n  font-size: 1.1875rem;\n  line-height: 1.3;\n  letter-spacing: -0.01em;\n  color: var(--text);\n}\n\n.repo-description {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  font-family: var(--font-serif);\n  font-style: italic;\n  font-weight: 400;\n  font-size: 0.875rem;\n  line-height: 1.55;\n  color: var(--text-secondary);\n  margin-top: var(--space-1);\n}\n\n.repo-meta {\n  display: block;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.6875rem;\n  line-height: 1.4;\n  letter-spacing: 0.01em;\n  color: var(--text-tertiary);\n  margin-top: var(--space-2);\n}\n\n@media (min-width: 640px) {\n  .repo-name {\n    font-size: 1.375rem;\n  }\n\n  .repo-description {\n    font-size: 0.9375rem;\n  }\n\n  .repo-meta {\n    font-size: 0.75rem;\n  }\n}\n\n/* Hover — desktop only, full-bleed background */\n@media (hover: hover) {\n  .repo-card {\n    margin: 0 calc(var(--pad) * -1);\n    padding-left: var(--pad);\n    padding-right: var(--pad);\n  }\n\n  .repo-card:hover {\n    background: var(--bg-hover);\n  }\n\n  .repo-card:active {\n    background: var(--bg-active);\n    transition-duration: 80ms;\n  }\n}\n\n/* Focus-visible */\n.repo-card:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 4px;\n  border-radius: 2px;\n}\n\n/* -------------------------------------------------------------------\n   Chapter Title Page — §6.3\n   ------------------------------------------------------------------- */\n.chapter-title {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 100dvh;\n  text-align: center;\n  padding: var(--pad);\n  scroll-snap-align: start;\n}\n\n.chapter-title-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n}\n\n.chapter-name {\n  font-family: var(--font-serif);\n  font-weight: 300;\n  font-size: 1.875rem;\n  line-height: 1.15;\n  letter-spacing: -0.03em;\n  color: var(--text);\n}\n\n.chapter-description {\n  font-family: var(--font-serif);\n  font-style: italic;\n  font-weight: 400;\n  font-size: 0.9375rem;\n  line-height: 1.6;\n  color: var(--text-secondary);\n  margin-top: var(--space-3);\n  max-width: 28rem;\n}\n\n.chapter-title .dinkus {\n  margin-top: var(--space-8);\n}\n\n@media (min-width: 640px) {\n  .chapter-name {\n    font-size: 2.5rem;\n  }\n\n  .chapter-description {\n    font-size: 1rem;\n  }\n}\n\n/* Scroll prompt — fades after 4s */\n.scroll-prompt {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-2);\n  padding-bottom: var(--space-10);\n  animation: promptFade 1200ms ease-out 4s forwards;\n}\n\n.scroll-prompt-text {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.6875rem;\n  line-height: 1;\n  letter-spacing: 0.08em;\n  color: var(--text-tertiary);\n  text-transform: uppercase;\n}\n\n.scroll-prompt-arrow {\n  font-size: 1rem;\n  color: var(--text-tertiary);\n  animation: bounce 1.8s ease-in-out infinite;\n}\n\n@keyframes promptFade {\n  to { opacity: 0; visibility: hidden; }\n}\n\n@keyframes bounce {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(6px); }\n}\n\n@media (min-width: 640px) {\n  .scroll-prompt-text {\n    font-size: 0.75rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Scroll Container — §6.3\n   ------------------------------------------------------------------- */\n.scroll-container {\n  height: 100dvh;\n  overflow-y: auto;\n  scroll-snap-type: y mandatory;\n  -webkit-overflow-scrolling: touch;\n  overscroll-behavior-y: contain;\n}\n\n/* -------------------------------------------------------------------\n   Commit Page — §6.4\n   ------------------------------------------------------------------- */\n.commit-page {\n  display: flex;\n  flex-direction: column;\n  min-height: 100dvh;\n  scroll-snap-align: start;\n  opacity: 0;\n  transform: translateY(12px);\n  transition: opacity 400ms ease-out, transform 400ms ease-out;\n}\n\n.commit-page.visible {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n.reading-column {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  max-width: 38rem;\n  width: 100%;\n  margin: 0 auto;\n  padding: 64px var(--pad) 32px;\n}\n\n@media (min-width: 640px) {\n  .reading-column {\n    padding-top: 80px;\n    padding-bottom: 48px;\n  }\n}\n\n.commit-title {\n  font-family: var(--font-serif);\n  font-weight: 700;\n  font-size: 1.3125rem;\n  line-height: 1.35;\n  letter-spacing: -0.015em;\n  color: var(--text);\n}\n\n@media (min-width: 640px) {\n  .commit-title {\n    font-size: 1.625rem;\n  }\n}\n\n.decorative-rule {\n  width: 3rem;\n  height: 1px;\n  background: var(--divider);\n  margin: var(--space-6) auto;\n}\n\n.commit-body {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  font-size: 1.0625rem;\n  line-height: 1.9;\n  letter-spacing: 0.003em;\n  color: var(--text);\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-wrap: break-word;\n}\n\n@media (min-width: 640px) {\n  .commit-body {\n    font-size: 1.125rem;\n  }\n}\n\n.lead-in {\n  font-variant: small-caps;\n  font-weight: 600;\n  letter-spacing: 0.05em;\n}\n\n.commit-footer {\n  margin-top: auto;\n  padding-top: var(--space-10);\n}\n\n.commit-meta-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n}\n\n.commit-date {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.75rem;\n  line-height: 1;\n  letter-spacing: 0.01em;\n  color: var(--text-secondary);\n}\n\n@media (min-width: 640px) {\n  .commit-date {\n    font-size: 0.8125rem;\n  }\n}\n\n.commit-sha {\n  font-family: var(--font-mono);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.05em;\n  color: var(--text-tertiary);\n}\n\n@media (min-width: 640px) {\n  .commit-sha {\n    font-size: 0.6875rem;\n  }\n}\n\n.commit-counter {\n  text-align: center;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.04em;\n  color: var(--text-tertiary);\n  margin-top: var(--space-2);\n}\n\n@media (min-width: 640px) {\n  .commit-counter {\n    font-size: 0.6875rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Top Bar — §6.5\n   ------------------------------------------------------------------- */\n.top-bar {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  z-index: 100;\n  height: 48px;\n  padding: 0 var(--pad);\n  padding-top: env(safe-area-inset-top, 0);\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  background: var(--bg-elevated);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid var(--divider);\n  opacity: 1;\n  transform: translateY(0);\n  transition: opacity 300ms ease, transform 300ms ease;\n}\n\n.top-bar.hidden {\n  opacity: 0;\n  transform: translateY(-100%);\n  pointer-events: none;\n}\n\n.back-button {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 44px;\n  height: 44px;\n  padding: 0;\n  background: transparent;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  font-family: var(--font-serif);\n  font-size: 1.25rem;\n  color: var(--text);\n  transition: background 150ms ease;\n}\n\n.back-button:hover {\n  background: var(--bg-hover);\n}\n\n.back-button:active {\n  background: var(--bg-active);\n}\n\n.back-button:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n\n.top-bar-title {\n  font-family: var(--font-sans);\n  font-weight: 500;\n  font-size: 0.75rem;\n  line-height: 1;\n  color: var(--text-secondary);\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n@media (min-width: 640px) {\n  .top-bar-title {\n    font-size: 0.8125rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Reading Progress Bar — §6.6\n   ------------------------------------------------------------------- */\n.progress-bar {\n  position: fixed;\n  top: 0;\n  left: 0;\n  height: 2px;\n  z-index: 200;\n  background: var(--accent);\n  opacity: 0.5;\n  width: 0%;\n  transition: width 300ms ease-out;\n}\n\n/* -------------------------------------------------------------------\n   Spinner — §6.7\n   ------------------------------------------------------------------- */\n.spinner-wrapper {\n  display: flex;\n  justify-content: center;\n  padding: var(--space-12) 0;\n}\n\n.spinner {\n  width: 20px;\n  height: 20px;\n  border: 1.5px solid var(--divider);\n  border-top-color: var(--accent);\n  border-radius: 50%;\n  animation: spin 0.8s linear infinite;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n/* -------------------------------------------------------------------\n   Error / Empty States — §6.8\n   ------------------------------------------------------------------- */\n.error-message {\n  text-align: center;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.9rem;\n  line-height: 1.6;\n  color: var(--text-secondary);\n  max-width: 28rem;\n  margin: var(--space-12) auto 0;\n}\n\n/* -------------------------------------------------------------------\n   Reduced Motion — §8\n   ------------------------------------------------------------------- */\n@media (prefers-reduced-motion: reduce) {\n  *,\n  *::before,\n  *::after {\n    animation-duration: 0.01ms !important;\n    transition-duration: 0.01ms !important;\n    scroll-behavior: auto !important;\n  }\n}\n","numLines":693,"startLine":1,"totalLines":693}}}
