if;\n  --font-mono:  'JetBrains Mono', 'SF Mono', 'Fira Code', 'Consolas', monospace;\n\n  /* Spacing tokens — §5 */\n  --space-1:  0.25rem;\n  --space-2:  0.5rem;\n  --space-3:  0.75rem;\n  --space-4:  1rem;\n  --space-5:  1.25rem;\n  --space-6:  1.5rem;\n  --space-8:  2rem;\n  --space-10: 2.5rem;\n  --space-12: 3rem;\n  --space-16: 4rem;\n  --space-20: 5rem;\n  --space-24: 6rem;\n\n  /* Page padding — §5 */\n  --pad: 24px;\n}\n\n@media (min-width: 640px) {\n  :root {\n    --pad: 40px;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Custom Properties — Dark mode\n   ------------------------------------------------------------------- */\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg:             #1a1916;\n    --bg-elevated:    #222019;\n    --bg-hover:       #2a2720;\n    --bg-active:      #333028;\n    --text:           #d9d4ca;\n    --text-secondary: #7d786f;\n    --text-tertiary:  #4a4740;\n    --accent:         #c9a96e;\n    --divider:        #2e2b25;\n    --selection:      rgba(201, 169, 110, 0.25);\n  }\n}\n\n/* -------------------------------------------------------------------\n   Base Reset\n   ------------------------------------------------------------------- */\n*,\n*::before,\n*::after {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\n/* -------------------------------------------------------------------\n   Base Styles — html / body\n   ------------------------------------------------------------------- */\nhtml {\n  font-size: 16px;\n  -webkit-text-size-adjust: 100%;\n  text-size-adjust: 100%;\n}\n\nbody {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  color: var(--text);\n  background-color: var(--bg);\n  line-height: 1.6;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\n/* -------------------------------------------------------------------\n   Text Selection — §3\n   ------------------------------------------------------------------- */\n::selection {\n  background: var(--selection);\n}\n\n/* -------------------------------------------------------------------\n   Screen Reader Only — §9\n   ------------------------------------------------------------------- */\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.sr-only-focusable:focus {\n  position: static;\n  width: auto;\n  height: auto;\n  padding: 0.5rem 1rem;\n  margin: 0;\n  overflow: visible;\n  clip: auto;\n  white-space: normal;\n}\n\n/* -------------------------------------------------------------------\n   View Transitions — §8\n   ------------------------------------------------------------------- */\n.view {\n  opacity: 0;\n  transition: opacity 250ms ease;\n}\n\n.view.view-visible {\n  opacity: 1;\n}\n\n.view.view-hidden {\n  opacity: 0;\n}\n\n/* -------------------------------------------------------------------\n   Content Container\n   ------------------------------------------------------------------- */\n.repo-list {\n  max-width: 42rem;\n  margin: 0 auto;\n  padding: 0 var(--pad);\n}\n\n/* -------------------------------------------------------------------\n   Hero — §6.1\n   ------------------------------------------------------------------- */\n.hero {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-align: center;\n  min-height: 15vh;\n  padding: var(--space-10) var(--pad) var(--space-8);\n}\n\n.hero-title {\n  font-family: var(--font-serif);\n  font-weight: 300;\n  font-size: 2.25rem;\n  line-height: 1.1;\n  letter-spacing: -0.04em;\n  color: var(--text);\n}\n\n.hero-tagline {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.8125rem;\n  line-height: 1.6;\n  letter-spacing: 0.02em;\n  color: var(--text-secondary);\n  margin-top: var(--space-3);\n  text-transform: lowercase;\n}\n\n.dinkus {\n  font-size: 0.75rem;\n  color: var(--text-tertiary);\n  margin-top: var(--space-6);\n  letter-spacing: 0.2em;\n}\n\n@media (min-width: 640px) {\n  .hero {\n    min-height: 25vh;\n    padding: var(--space-16) var(--pad) var(--space-12);\n  }\n\n  .hero-title {\n    font-size: 3rem;\n  }\n\n  .hero-tagline {\n    font-size: 0.875rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Repo Cards — §6.2\n   ------------------------------------------------------------------- */\n.repo-list-items {\n  padding-top: var(--space-4);\n}\n\n.repo-card {\n  display: block;\n  padding: var(--space-6) 0;\n  border-bottom: 1px solid var(--divider);\n  text-decoration: none;\n  color: inherit;\n  transition: background 200ms ease;\n}\n\n.repo-card:first-child {\n  border-top: 1px solid var(--divider);\n}\n\n.repo-name {\n  display: block;\n  font-family: var(--font-serif);\n  font-weight: 600;\n  font-size: 1.1875rem;\n  line-height: 1.3;\n  letter-spacing: -0.01em;\n  color: var(--text);\n}\n\n.repo-description {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  font-family: var(--font-serif);\n  font-style: italic;\n  font-weight: 400;\n  font-size: 0.875rem;\n  line-height: 1.55;\n  color: var(--text-secondary);\n  margin-top: var(--space-1);\n}\n\n.repo-meta {\n  display: block;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.6875rem;\n  line-height: 1.4;\n  letter-spacing: 0.01em;\n  color: var(--text-tertiary);\n  margin-top: var(--space-2);\n}\n\n@media (min-width: 640px) {\n  .repo-name {\n    font-size: 1.375rem;\n  }\n\n  .repo-description {\n    font-size: 0.9375rem;\n  }\n\n  .repo-meta {\n    font-size: 0.75rem;\n  }\n}\n\n/* Hover — desktop only, full-bleed background */\n@media (hover: hover) {\n  .repo-card {\n    margin: 0 calc(var(--pad) * -1);\n    padding-left: var(--pad);\n    padding-right: var(--pad);\n  }\n\n  .repo-card:hover {\n    background: var(--bg-hover);\n  }\n\n  .repo-card:active {\n    background: var(--bg-active);\n    transition-duration: 80ms;\n  }\n}\n\n/* Focus-visible */\n.repo-card:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 4px;\n  border-radius: 2px;\n}\n\n/* -------------------------------------------------------------------\n   Chapter Title Page — §6.3\n   ------------------------------------------------------------------- */\n.chapter-title {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  min-height: 100dvh;\n  text-align: center;\n  padding: var(--pad);\n  scroll-snap-align: start;\n}\n\n.chapter-title-content {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n}\n\n.chapter-name {\n  font-family: var(--font-serif);\n  font-weight: 300;\n  font-size: 1.875rem;\n  line-height: 1.15;\n  letter-spacing: -0.03em;\n  color: var(--text);\n}\n\n.chapter-description {\n  font-family: var(--font-serif);\n  font-style: italic;\n  font-weight: 400;\n  font-size: 0.9375rem;\n  line-height: 1.6;\n  color: var(--text-secondary);\n  margin-top: var(--space-3);\n  max-width: 28rem;\n}\n\n.chapter-title .dinkus {\n  margin-top: var(--space-8);\n}\n\n@media (min-width: 640px) {\n  .chapter-name {\n    font-size: 2.5rem;\n  }\n\n  .chapter-description {\n    font-size: 1rem;\n  }\n}\n\n/* Scroll prompt — fades after 4s */\n.scroll-prompt {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--space-2);\n  padding-bottom: var(--space-10);\n  animation: promptFade 1200ms ease-out 4s forwards;\n}\n\n.scroll-prompt-text {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.6875rem;\n  line-height: 1;\n  letter-spacing: 0.08em;\n  color: var(--text-tertiary);\n  text-transform: uppercase;\n}\n\n.scroll-prompt-arrow {\n  font-size: 1rem;\n  color: var(--text-tertiary);\n  animation: bounce 1.8s ease-in-out infinite;\n}\n\n@keyframes promptFade {\n  to { opacity: 0; visibility: hidden; }\n}\n\n@keyframes bounce {\n  0%, 100% { transform: translateY(0); }\n  50% { transform: translateY(6px); }\n}\n\n@media (min-width: 640px) {\n  .scroll-prompt-text {\n    font-size: 0.75rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Scroll Container — §6.3\n   ------------------------------------------------------------------- */\n.scroll-container {\n  height: 100dvh;\n  overflow-y: auto;\n  scroll-snap-type: y mandatory;\n  -webkit-overflow-scrolling: touch;\n  overscroll-behavior-y: contain;\n}\n\n/* -------------------------------------------------------------------\n   Commit Page — §6.4\n   ------------------------------------------------------------------- */\n.commit-page {\n  display: flex;\n  flex-direction: column;\n  min-height: 100dvh;\n  scroll-snap-align: start;\n  opacity: 0;\n  transform: translateY(12px);\n  transition: opacity 400ms ease-out, transform 400ms ease-out;\n}\n\n.commit-page.visible {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n.reading-column {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  max-width: 38rem;\n  width: 100%;\n  margin: 0 auto;\n  padding: 64px var(--pad) 32px;\n}\n\n@media (min-width: 640px) {\n  .reading-column {\n    padding-top: 80px;\n    padding-bottom: 48px;\n  }\n}\n\n.commit-title {\n  font-family: var(--font-serif);\n  font-weight: 700;\n  font-size: 1.3125rem;\n  line-height: 1.35;\n  letter-spacing: -0.015em;\n  color: var(--text);\n}\n\n@media (min-width: 640px) {\n  .commit-title {\n    font-size: 1.625rem;\n  }\n}\n\n.decorative-rule {\n  width: 3rem;\n  height: 1px;\n  background: var(--divider);\n  margin: var(--space-6) auto;\n}\n\n.commit-body {\n  font-family: var(--font-serif);\n  font-weight: 400;\n  font-size: 1.0625rem;\n  line-height: 1.9;\n  letter-spacing: 0.003em;\n  color: var(--text);\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-wrap: break-word;\n}\n\n@media (min-width: 640px) {\n  .commit-body {\n    font-size: 1.125rem;\n  }\n}\n\n.lead-in {\n  font-variant: small-caps;\n  font-weight: 600;\n  letter-spacing: 0.05em;\n}\n\n.commit-footer {\n  margin-top: auto;\n  padding-top: var(--space-10);\n}\n\n.commit-meta-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n}\n\n.commit-date {\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.75rem;\n  line-height: 1;\n  letter-spacing: 0.01em;\n  color: var(--text-secondary);\n}\n\n@media (min-width: 640px) {\n  .commit-date {\n    font-size: 0.8125rem;\n  }\n}\n\n.commit-sha {\n  font-family: var(--font-mono);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.05em;\n  color: var(--text-tertiary);\n}\n\n@media (min-width: 640px) {\n  .commit-sha {\n    font-size: 0.6875rem;\n  }\n}\n\n.commit-counter {\n  text-align: center;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-size: 0.625rem;\n  line-height: 1;\n  letter-spacing: 0.04em;\n  color: var(--text-tertiary);\n  margin-top: var(--space-2);\n}\n\n@media (min-width: 640px) {\n  .commit-counter {\n    font-size: 0.6875rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Top Bar — §6.5\n   ------------------------------------------------------------------- */\n.top-bar {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  z-index: 100;\n  height: 48px;\n  padding: 0 var(--pad);\n  padding-top: env(safe-area-inset-top, 0);\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  background: var(--bg-elevated);\n  backdrop-filter: blur(16px);\n  -webkit-backdrop-filter: blur(16px);\n  border-bottom: 1px solid var(--divider);\n  opacity: 1;\n  transform: translateY(0);\n  transition: opacity 300ms ease, transform 300ms ease;\n}\n\n.top-bar.hidden {\n  opacity: 0;\n  transform: translateY(-100%);\n  pointer-events: none;\n}\n\n.back-button {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 44px;\n  height: 44px;\n  padding: 0;\n  background: transparent;\n  border: none;\n  border-radius: 6px;\n  cursor: pointer;\n  font-family: var(--font-serif);\n  font-size: 1.25rem;\n  color: var(--text);\n  transition: background 150ms ease;\n}\n\n.back-button:hover {\n  background: var(--bg-hover);\n}\n\n.back-button:active {\n  background: var(--bg-active);\n}\n\n.back-button:focus-visible {\n  outline: 2px solid var(--accent);\n  outline-offset: 2px;\n}\n\n.top-bar-title {\n  font-family: var(--font-sans);\n  font-weight: 500;\n  font-size: 0.75rem;\n  line-height: 1;\n  color: var(--text-secondary);\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n@media (min-width: 640px) {\n  .top-bar-title {\n    font-size: 0.8125rem;\n  }\n}\n\n/* -------------------------------------------------------------------\n   Reading Progress Bar — §6.6\n   ------------------------------------------------------------------- */\n.progress-bar {\n  position: fixed;\n  top: 0;\n  left: 0;\n  height: 2px;\n  z-index: 200;\n  background: var(--accent);\n  opacity: 0.5;\n  width: 0%;\n  transition: width 300ms ease-out;\n}\n\n/* -------------------------------------------------------------------\n   Spinner — §6.7\n   ------------------------------------------------------------------- */\n.spinner-wrapper {\n  display: flex;\n  justify-content: center;\n  padding: var(--space-12) 0;\n}\n\n.spinner {\n  width: 20px;\n  height: 20px;\n  border: 1.5px solid var(--divider);\n  border-top-color: var(--accent);\n  border-radius: 50%;\n  animation: spin 0.8s linear infinite;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n/* -------------------------------------------------------------------\n   Error / Empty States — §6.8\n   ------------------------------------------------------------------- */\n.error-message {\n  text-align: center;\n  font-family: var(--font-sans);\n  font-weight: 400;\n  font-